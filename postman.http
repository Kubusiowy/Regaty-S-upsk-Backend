### Auth login: POST /auth/login
POST {{host}}/auth/login
Content-Type: application/json
Accept: application/json

{
  "login": "{{adminLogin}}",
  "rawPassword": "{{adminPassword}}"
}

> {%
    client.test("POST /auth/login returns 200 and tokens", function() {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.accessToken, "Missing accessToken");
    });

    client.global.set("accessToken", response.body.accessToken);
    client.global.set("refreshToken", response.body.refreshToken);
%}

### Auth refresh: POST /auth/refresh
POST {{host}}/auth/refresh
Content-Type: application/json
Accept: application/json

{
  "refreshToken": "{{refreshToken}}"
}

> {%
    client.test("POST /auth/refresh returns 200 and access token", function() {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.accessToken, "Missing accessToken");
    });

    client.global.set("accessToken", response.body.accessToken);
%}

### Admin create category: POST /admin/categories
POST {{host}}/admin/categories
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Accept: application/json

{
  "name": "{{categoryName}}"
}

> {%
    client.test("POST /admin/categories returns 201 and id", function() {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id, "Missing category id");
    });

    client.global.set("categoryId", response.body.id);
%}

### Admin update category: PUT /admin/categories/{id}
PUT {{host}}/admin/categories/{{categoryId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Accept: application/json

{
  "name": "{{categoryUpdatedName}}"
}

> {%
    client.test("PUT /admin/categories/{id} returns 200", function() {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.id === client.global.get("categoryId"), "Updated category id mismatch");
    });
%}

