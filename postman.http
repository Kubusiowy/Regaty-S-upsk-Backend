### Unauthorized admin check: GET-like protected route is not defined, POST without token should return 401
POST {{host}}/admin/categories
Content-Type: application/json
Accept: application/json

{
  "name": "Unauthorized category"
}

> {%
    client.test("POST /admin/categories without token returns 401", function() {
        client.assert(response.status === 401, "Expected 401 Unauthorized");
    });
%}


