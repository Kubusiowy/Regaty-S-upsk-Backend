  "categoryId": "{{categoryId}}",
  "timeMs": {{resultTimeMs}}
}

> {%
    client.test("POST /admin/scores/add returns 200 and id", function() {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.id, "Missing result id");
    });

    client.global.set("resultId", response.body.id);
%}

